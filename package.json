{
	"name": "sveltekit-temporal",
	"author": "Scott Rhamy",
	"license": "MIT",
	"version": "1.0.1",
	"description": "sv add-on that wires the Temporal API polyfill into a SvelteKit project with conditional loading on client and server.",
	"type": "module",
	"exports": {
		".": "./dist/addon.js",
		"./sv": "./dist/addon.js"
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "esbuild src/addon.js --bundle --platform=node --format=esm --outfile=dist/addon.js --external:sv --external:node:*",
		"prepublishOnly": "npm run build"
	},
	"engines": {
		"node": ">=18"
	},
	"dependencies": {},
	"devDependencies": {
		"esbuild": "^0.25.0"
	},
	"peerDependencies": {
		"sv": "^0.15.3"
	},
	"keywords": [
		"sveltekit",
		"temporal",
		"polyfill",
		"sv-add",
		"sv-create",
		"sv"
	]
}
