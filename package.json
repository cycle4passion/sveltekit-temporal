{
	"name": "sveltekit-temporal",
	"author": "Scott Rhamy",
	"version": "0.2.0",
	"description": "Set up the Temporal API polyfill in a SvelteKit project with conditional loading on client and server.",
	"type": "module",
	"exports": {
		".": "./src/index.js",
		"./sv": "./src/addon.js"
	},
	"bin": {
		"sveltekit-temporal": "bin/cli.js"
	},
	"files": [
		"bin",
		"src",
		"README.md"
	],
	"engines": {
		"node": ">=18"
	},
	"dependencies": {
		"@clack/prompts": "^0.7.0",
		"picocolors": "^1.0.0"
	},
	"peerDependencies": {
		"sv": "*"
	},
	"peerDependenciesMeta": {
		"sv": {
			"optional": true
		}
	},
	"keywords": [
		"svelte",
		"sveltekit",
		"temporal",
		"polyfill",
		"cli",
		"sv-add"
	],
	"license": "MIT"
}
